{
  "name": "@propeller-commerce/propeller-v2-mollie",
  "version": "0.2.4",
  "description": "Mollie PSP payment provider for the Propeller eCommerce V2 platform — drives Mollie payments through the Propeller GraphQL API via @propeller-commerce/propeller-sdk-v2. Server-side, framework-agnostic.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/fix-esm-extensions.js && node scripts/write-esm-package-json.js",
    "build": "npm run build:cjs && npm run build:esm",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit -p tsconfig.cjs.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "validate": "npm run typecheck && npm run test:ci && npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run validate"
  },
  "keywords": [
    "mollie",
    "psp",
    "payments",
    "propeller",
    "ecommerce",
    "graphql",
    "typescript",
    "v2",
    "payment-provider"
  ],
  "author": "Propeller Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/propeller-commerce/propeller-v2-mollie.git"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@mollie/api-client": "^4.0.0"
  },
  "peerDependencies": {
    "@propeller-commerce/propeller-sdk-v2": "*"
  },
  "devDependencies": {
    "@propeller-commerce/propeller-sdk-v2": "^0.12.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
